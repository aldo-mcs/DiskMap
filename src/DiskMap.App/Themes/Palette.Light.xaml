<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime"
                    xmlns:infra="clr-namespace:DiskMap.App.Infrastructure">

    <!-- ===== Palette — same structure as Palette.Dark.xaml, light values. Same restraint:
         muted, low-saturation chrome; color stays reserved for data (file types). ===== -->
    <Color x:Key="BackgroundColor">#F3F3F4</Color>
    <SolidColorBrush x:Key="BackgroundBrush" Color="#F3F3F4"/>
    <SolidColorBrush x:Key="TitleBarBrush" Color="#E7E7E9"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="#EBEBED"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#D2D2D6"/>
    <SolidColorBrush x:Key="BorderSubtleBrush" Color="#E1E1E4"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1B1C1F"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#5B5E66"/>
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="#8A8D94"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#2E6DA4"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#3E80BA"/>
    <SolidColorBrush x:Key="AccentDeepBrush" Color="#C2DBEF"/>
    <SolidColorBrush x:Key="SelectionBrush" Color="#D6E6F5"/>
    <SolidColorBrush x:Key="HoverBrush" Color="#E9E9EC"/>
    <!-- CoralBrush: warm red, shared by the donation heart icon and History's "grew" indicator —
         named for its color, not either specific use. ShrinkBrush is growth-indicator-only. -->
    <SolidColorBrush x:Key="CoralBrush" Color="#C0463B"/>
    <SolidColorBrush x:Key="ShrinkBrush" Color="#2E8B4F"/>
    <SolidColorBrush x:Key="CloseHoverBrush" Color="#C0392B"/>

    <FontFamily x:Key="MonoFont">Consolas</FontFamily>

    <!-- ===== Converters ===== -->
    <infra:BytesConverter x:Key="Bytes"/>
    <infra:SignedBytesConverter x:Key="SignedBytes"/>
    <infra:DepthToMarginConverter x:Key="DepthToMargin"/>
    <infra:PercentageToWidthConverter x:Key="PctToWidth"/>
    <infra:BoolToVisibilityConverter x:Key="BoolToVis"/>
    <infra:BoolToOpacityConverter x:Key="BoolToOpacity"/>

    <sys:Double x:Key="RowFontSize">12.5</sys:Double>

</ResourceDictionary>
