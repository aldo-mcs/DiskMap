<Window x:Class="DiskMap.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Settings" Height="600" Width="460" Icon="../diskmap.ico"
        WindowStyle="None" ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False" UseLayoutRounding="True">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="32" ResizeBorderThickness="0" CornerRadius="0" GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border Background="{DynamicResource BackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <DockPanel>
            <Grid DockPanel.Dock="Top" Height="32" Background="{DynamicResource TitleBarBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Settings" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="12,0" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Style="{StaticResource CloseCaptionButton}" Content="&#xE8BB;" Click="OnCancel"
                        Width="40" Height="32" shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
            </Grid>

            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="20,12,20,16">
                <Button Content="Cancel" Click="OnCancel" Margin="0,0,8,0" Padding="14,6"/>
                <Button Style="{StaticResource AccentButton}" Content="Save" Click="OnSave" Padding="14,6" IsDefault="True"/>
            </StackPanel>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20,16,20,4">

                    <TextBlock Text="APPEARANCE" Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <RadioButton x:Name="ThemeSystemRadio" GroupName="Theme" Content="Match system" Margin="0,0,16,0"/>
                        <RadioButton x:Name="ThemeLightRadio" GroupName="Theme" Content="Light" Margin="0,0,16,0"/>
                        <RadioButton x:Name="ThemeDarkRadio" GroupName="Theme" Content="Dark"/>
                    </StackPanel>

                    <TextBlock Text="SCANNING" Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
                    <TextBlock Text="Scan speed" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <RadioButton x:Name="ScanFastRadio" GroupName="ScanMode" Content="Fast" Margin="0,0,16,0"
                                     ToolTip="Full parallelism (all cores). Best when the machine is otherwise idle."/>
                        <RadioButton x:Name="ScanBalancedRadio" GroupName="ScanMode" Content="Balanced" Margin="0,0,16,0"
                                     ToolTip="Half the cores. The default — responsive without saturating the machine."/>
                        <RadioButton x:Name="ScanLowRadio" GroupName="ScanMode" Content="Low impact"
                                     ToolTip="Two workers, background I/O priority. Won't compete with foreground work."/>
                    </StackPanel>

                    <TextBlock Text="Reparse points (junctions / directory symlinks)" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <RadioButton x:Name="ReparseIgnoreRadio" GroupName="Reparse" Content="Ignore" Margin="0,0,16,0"
                                     ToolTip="Not listed at all."/>
                        <RadioButton x:Name="ReparseShowRadio" GroupName="Reparse" Content="Show" Margin="0,0,16,0"
                                     ToolTip="Listed but never followed. The default — avoids cycles and double-counting."/>
                        <RadioButton x:Name="ReparseFollowRadio" GroupName="Reparse" Content="Follow"
                                     ToolTip="Followed into the target. Cycle-safe, but content reachable through multiple links is only counted once."/>
                    </StackPanel>

                    <TextBlock Text="Minimum file size for duplicate detection" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBox x:Name="MinDuplicateSizeBox" Width="140" HorizontalAlignment="Left" Margin="0,0,0,14" ToolTip="e.g. 1 B, 100 KB, 4 MB"/>

                    <CheckBox x:Name="MemorySaverCheck" Content="Memory saver — trim large unexpanded folders to bound memory on huge drives" Margin="0,0,0,8"/>
                    <CheckBox x:Name="CrashSafeResumeCheck" Content="Resume interrupted scans automatically" Margin="0,0,0,20"/>

                    <TextBlock Text="ELEVATION" Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
                    <CheckBox x:Name="AlwaysElevatedCheck" Content="Always start elevated" Checked="OnAlwaysElevatedChanged" Unchecked="OnAlwaysElevatedChanged" Margin="0,0,0,6"/>
                    <TextBlock x:Name="ElevationWarningText" TextWrapping="Wrap" Foreground="{DynamicResource CloseHoverBrush}" FontSize="11.5" Margin="0,0,0,20" Visibility="Collapsed"
                               Text="⚠ Restarting as Administrator each launch triggers a UAC prompt."/>

                    <TextBlock Text="DIAGNOSTICS" Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
                    <Button Content="Open settings folder" Click="OnOpenSettingsFolder" HorizontalAlignment="Left" Padding="10,5"/>

                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Border>
</Window>
