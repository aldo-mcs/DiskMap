<Window x:Class="DiskMap.App.Views.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="DiskMap — History" Height="560" Width="820" Icon="../diskmap.ico"
        WindowStyle="None" ResizeMode="CanResize" WindowStartupLocation="CenterOwner"
        UseLayoutRounding="True">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="32" ResizeBorderThickness="6" CornerRadius="0" GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border x:Name="RootBorder" Background="{DynamicResource BackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <DockPanel>
            <Grid DockPanel.Dock="Top" Height="32" Background="{DynamicResource TitleBarBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Margin="12,0" VerticalAlignment="Center">
                    <Image Source="../diskmap.ico" Width="14" Height="14" Margin="0,0,7,0"/>
                    <TextBlock Text="History — What Changed" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                </StackPanel>
                <Button Grid.Column="1" Style="{StaticResource CloseCaptionButton}" Content="&#xE8BB;" Click="OnClose"
                        Width="40" Height="32" shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
            </Grid>

            <DockPanel Margin="12">
                <TextBlock DockPanel.Dock="Top" Text="Compare two snapshots of the same folder to see which directories grew or shrank."
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,10" TextWrapping="Wrap"/>

                <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Baseline (older)" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <ComboBox x:Name="BaselineCombo" SelectionChanged="OnSelectionChanged">
                            <ComboBox.ItemTemplate>
                                <DataTemplate><TextBlock Text="{Binding Display}"/></DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Compare (newer)" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <ComboBox x:Name="CompareCombo" SelectionChanged="OnSelectionChanged">
                            <ComboBox.ItemTemplate>
                                <DataTemplate><TextBlock Text="{Binding Display}"/></DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <TextBlock x:Name="SummaryText" DockPanel.Dock="Top" Margin="0,0,0,8" FontWeight="SemiBold"/>

                <ListView x:Name="DiffList">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Directory" Width="420" DisplayMemberBinding="{Binding Path}"/>
                            <GridViewColumn Header="Before" Width="110">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate><TextBlock Text="{Binding OldText}" FontFamily="{DynamicResource MonoFont}" HorizontalAlignment="Right"/></DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="After" Width="110">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate><TextBlock Text="{Binding NewText}" FontFamily="{DynamicResource MonoFont}" HorizontalAlignment="Right"/></DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Change" Width="120">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate><TextBlock Text="{Binding ChangeText}" FontFamily="{DynamicResource MonoFont}" Foreground="{Binding ChangeBrush}" HorizontalAlignment="Right" FontWeight="SemiBold"/></DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </DockPanel>
        </DockPanel>
    </Border>
</Window>
