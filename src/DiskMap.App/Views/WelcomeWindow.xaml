<Window x:Class="DiskMap.App.Views.WelcomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Welcome to DiskMap" Height="430" Width="440" Icon="../diskmap.ico"
        WindowStyle="None" ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False" UseLayoutRounding="True">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="32" ResizeBorderThickness="0" CornerRadius="0" GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border Background="{DynamicResource BackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <DockPanel>
            <Grid DockPanel.Dock="Top" Height="32" Background="{DynamicResource TitleBarBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Welcome" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="12,0" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Style="{StaticResource CloseCaptionButton}" Content="&#xE8BB;" Click="OnClose"
                        Width="40" Height="32" shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
            </Grid>

            <StackPanel Margin="28,22" HorizontalAlignment="Center">
                <Image Source="../diskmap.ico" Width="56" Height="56" Margin="0,0,0,14"/>
                <TextBlock Text="Thanks for downloading DiskMap!" FontSize="17" FontWeight="Bold" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="360"/>
                <TextBlock Margin="0,10,0,0" TextWrapping="Wrap" TextAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" MaxWidth="360"
                           Text="A fast, no-bloat disk usage analyzer. Scan a drive, see where your space went, and clean it up."/>

                <Rectangle Height="1" Fill="{DynamicResource BorderSubtleBrush}" Margin="0,20,0,16" Width="300"/>

                <TextBlock Text="DiskMap is free and independently built." Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11.5" HorizontalAlignment="Center"/>
                <TextBlock Text="If it's useful to you, a donation goes a long way:" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11.5" HorizontalAlignment="Center" Margin="0,2,0,14"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Click="OnGitHubSponsor" Padding="12,7" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource VectorIcon16}" Data="{StaticResource GitHubIconGeometry}" Fill="{DynamicResource TextPrimaryBrush}" Margin="0,0,7,0"/>
                            <TextBlock Text="GitHub Sponsors"/>
                        </StackPanel>
                    </Button>
                    <Button Click="OnStripeDonate" Padding="12,7">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource VectorIcon16}" Data="{StaticResource HeartIconGeometry}" Fill="{DynamicResource CoralBrush}" Margin="0,0,7,0"/>
                            <TextBlock Text="Donate via Stripe"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <Button Style="{StaticResource AccentButton}" Content="Get Started" Click="OnClose" Padding="16,7" Margin="0,20,0,0" HorizontalAlignment="Center"/>

                <CheckBox x:Name="DontShowAgainCheck" Content="Don't show this again" HorizontalAlignment="Center" Margin="0,14,0,0"
                          Foreground="{DynamicResource TextSecondaryBrush}"/>
            </StackPanel>
        </DockPanel>
    </Border>
</Window>
